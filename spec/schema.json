{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tower Building game.json",
  "type": "object",
  "required": ["name", "canvas", "milestones", "dayNightColorStops", "cloudPositions"],
  "properties": {
    "name": { "type": "string" },
    "gameId": { "type": "string" },
    "gameTypeLabel": { "type": "string" },
    "version": { "type": "string" },
    "canvas": {
      "type": "object",
      "required": ["ratio"],
      "properties": {
        "ratio": { "type": "number", "exclusiveMinimum": 0 },
        "highResolution": { "type": "boolean" }
      }
    },
    "modules": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["floor", "flightId", "type"],
        "properties": {
          "floor": { "type": "integer", "minimum": 0 },
          "flightId": { "type": "integer", "minimum": 1 },
          "type": {
            "type": "string",
            "enum": ["leftToRight", "rightToLeft", "bottomToTop", "rightTopToLeft"]
          }
        }
      }
    },
    "dayNightColorStops": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": { "type": "integer", "minimum": 0, "maximum": 255 }
      }
    },
    "cloudPositions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["x", "y"],
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      }
    }
  }
}
